# ── Tier selection ─────────────────────────────────────────────────────────────
# "A" = CPU-only (default)  |  "B" = single small GPU
HARDWARE_TIER=A

# ── Ollama / llama.cpp server ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Clients root dir ──────────────────────────────────────────────────────────
CLIENTS_DIR=./clients
